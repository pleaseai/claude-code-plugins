{
  "description": "RTK: rewrite Bash commands to use rtk for token-optimized output",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/rtk-rewrite.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
