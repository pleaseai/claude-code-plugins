{
  "description": "Inject Graphite context at session start when .git/.graphite_repo_config is present",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/graphite-context.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
