{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-binary-doc.sh",
            "if": "Read(*.pptx)|Read(*.docx)|Read(*.xlsx)|Read(*.xls)|Read(*.ppt)|Read(*.doc)",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
