{
  "name": "nanobanana",
  "version": "1.0.1",
  "description": "Gemini CLI extension for Nano Banana (Gemini 2.5 Flash Image) model - generate and manipulate images with text prompts",
  "author": {
    "name": "gemini-cli-extensions",
    "url": "https://github.com/gemini-cli-extensions"
  },
  "homepage": "https://github.com/gemini-cli-extensions/nanobanana",
  "repository": "https://github.com/gemini-cli-extensions/nanobanana",
  "license": "Apache-2.0",
  "keywords": ["nanobanana"],
  "mcpServers": {
    "nanobanana": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/mcp-server/dist/index.js"
      ],
      "env": {}
    }
  },
  "commands": [
    "./commands"
  ]
}
