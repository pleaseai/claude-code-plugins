{
  "description": "Nuxt UI component guidance: reminds LLMs to verify v4 API via MCP before writing Vue files",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/check-vue-components.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
